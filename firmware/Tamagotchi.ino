}
//------------AUTO UPDATE------------
unsigned long lastUpdate = 0;
unsigned long lastInteractionTime = 0;
const unsigned long interactionTimeout = 15000; //idle 15 sec

void updatePet(){
  if (millis() - lastUpdate > 5000){  // every 5 seconds

    if (currentTemp < 10.0){
      pet.energy -= 5;
      pet.hunger -= 2;
      pet.happiness -= 2;
    }
    else if (currentTemp > 30.0){
      pet.energy -= 3;
      pet.hunger -= 2;
      pet.happiness -= 3;
    }
    else{
      pet.hunger--;
      pet.energy-=3;
      if (millis() - lastInteractionTime > interactionTimeout){
        pet.happiness--;
      } // down w/o interactions (buttons/joystick)
    }

    if (pet.hunger < 0) pet.hunger = 0;
    if (pet.happiness < 0) pet.happiness = 0;
    if (pet.energy < 0) pet.energy = 0;

    pet.age += 5;
    lastUpdate = millis();
  }
}

//------------BUTTON READING------------
void checkButtons(){
  if (millis() - lastButtonPress < 200) return;  // debounce: ignore presses within 200ms

  bool topBtn = (digitalRead(BTN_TOP) == LOW);
  bool midBtn = (digitalRead(BTN_MIDDLE) == LOW);
  bool btmBtn = (digitalRead(BTN_BOTTOM) == LOW);

  //ttt p1
  if (tttPlaying){
    int currentX = analogRead(X_PIN) - xCenter;
    int currentY = analogRead(Y_PIN) - yCenter;

    if (abs(currentX) > deadzone || abs(currentY) > deadzone){
      if (!joystickMoving){
        joystickMoving = true;
        lastInteractionTime = millis();
          if (abs(currentX) > abs(currentY)){
            if (currentX > 0) cursorX++; //right
            else cursorX--; //left
          }else{
            if (currentY > 0) cursorY--; //up
            else cursorY++; //down
          }

          if (cursorX > 2) cursorX = 0;
          if (cursorX < 0) cursorX = 2;
          if (cursorY > 2) cursorY = 0;
          if (cursorY < 0) cursorY = 2;
          tone(BUZZER_PIN, 1100, 30);
      }
    }else{
      joystickMoving = false;
    }

    if (btmBtn){
      tttPlaying = false;
      tone(BUZZER_PIN, 600, 200);
      lastButtonPress = millis();
      return;
    }
    else if ((topBtn || midBtn) && playerTurn){
      if (tttBoard[cursorY][cursorX] == 0){
        tttBoard[cursorY][cursorX] = 1;
        tone(BUZZER_PIN, 1400, 60);
        playerTurn = false;

        bool petMoved = false;
        for (int r = 0; r < 3 && !petMoved; r++){
          for (int c = 0; c < 3 && !petMoved; c++){
            if (tttBoard[r][c] == 0){
              tttBoard[r][c] = 2;
              petMoved = true;
              playerTurn = true;
            }
          }
        }

        int result = tttEnd();
        if (result != 0){
          tttPlaying = false;

          if (result == 1){ //player wins
            pet.happiness += 10;
            tone(BUZZER_PIN, 1200, 100);
            delay(120);
            tone(BUZZER_PIN, 1500, 100);
            delay(120);
            tone(BUZZER_PIN, 1800, 200);
            delay(220);
          }
          else if (result == 2){ //pet wins
            pet.happiness += 15;
            tone(BUZZER_PIN, 1500, 100);
            delay(120);
            tone(BUZZER_PIN, 1200, 200);
            delay(220);
          }
          else if (result == 3){ //tie
            pet.happiness += 8;
            tone(BUZZER_PIN, 1000, 150);
            delay(150);
            tone(BUZZER_PIN, 1000, 250);
            delay(270);
          }

          noTone(BUZZER_PIN);
          if (pet.happiness > 100) pet.happiness = 100;
          lastButtonPress = millis();
          return;
          }
      }
    }
  }

  //found item
  if (itemSpawned && (topBtn || midBtn || btmBtn)){
    
    if (spawnedItemType == 0){
      pet.hunger += 2;
      if (pet.hunger > 100) pet.hunger = 100;
      tone(BUZZER_PIN, 1100, 100);
    } 
    else if (spawnedItemType == 1){
      pet.happiness += 3;
      if (pet.happiness > 100) pet.happiness = 100;
      tone(BUZZER_PIN, 1300, 100);
    }

    itemSpawned = false;
    lastButtonPress = millis();
    lastInteractionTime = millis();
    return;
  }

  if (topBtn || midBtn || btmBtn){
    lastInteractionTime = millis();
  }

  if (topBtn){
    currentScreen = SCREEN_FEED;
    tone(BUZZER_PIN, 1000, 50);
    lastButtonPress = millis();
  }
  else if (midBtn && btmBtn){ //added
    currentScreen = SCREEN_EXERCISE;
    tone(BUZZER_PIN, 800, 50);
    lastButtonPress = millis();
  }
  else if (midBtn){
    currentScreen = SCREEN_PLAY;
    tone(BUZZER_PIN, 1200, 50);
    lastButtonPress = millis();
  }
  else if (btmBtn){
    currentScreen = SCREEN_SLEEP;
    tone(BUZZER_PIN, 800, 50);
    lastButtonPress = millis();
  }
}
//------------SCREEN DISPLAY------------
void handleScreenLogic(){
  int gameChoice = 0;
  if (actionActive){
    if (millis() - actionStartTime >= actionDuration){
      actionActive = false;
      changeState(WALK_TOWARDS); 
    }
    return; 
  }

  switch(currentScreen) {
    case SCREEN_FEED:
      pet.hunger += 10;
      if (pet.hunger > 100) pet.hunger = 100;
      changeState(EATING);       
      actionActive = true;
      actionStartTime = millis();
      currentScreen = SCREEN_MAIN;
      break;

    case SCREEN_PLAY: //come back
      pet.happiness += 10;
      pet.energy -= 5;
      if (pet.happiness > 100) pet.happiness = 100;
      if (pet.energy < 0) pet.energy = 0;
      gameChoice = random(0, 3);

      if (gameChoice == 0) {
        changeState(HULA_HOOPING);  
        actionActive = true;
        actionStartTime = millis();
        currentScreen = SCREEN_MAIN;
      } 
      else if (gameChoice == 1) {
        changeState(JUMP_ROPING);  
        actionActive = true;
        actionStartTime = millis();
        currentScreen = SCREEN_MAIN;
      } 
      else {
        actionActive = false; 
        actionStartTime = 0;
        tttReset();
        tttPlaying = true;
        currentScreen = SCREEN_MAIN;
      }
      break;

    case SCREEN_SLEEP:
      pet.energy += 15;
      if (pet.energy > 100) pet.energy = 100;
      changeState(WALK_TOWARDS); 
      actionActive = true;
      actionStartTime = millis();
      currentScreen = SCREEN_MAIN;
      break;

    case SCREEN_EXERCISE:
      pet.energy -= 10;
      pet.hunger -= 5;
      pet.happiness += 5;
      if (pet.happiness > 100) pet.happiness = 100;
      if (pet.energy < 0) pet.energy = 0;
      if (pet.hunger < 0) pet.hunger = 0;
      
      if(random(0, 2) == 0) changeState(RUNNING);
      else changeState(LIFTING);
      
      actionActive = true;
      actionStartTime = millis();
      currentScreen = SCREEN_MAIN; 
      break;

    case SCREEN_MAIN:
      break;  // do nothing, just display stats
  }
}

void drawAnimation(const unsigned char** frameArray, int totalFrames, int speed, int x, int y){
  unsigned long currentTime = millis();
  if (currentTime - previousTime >= (unsigned long)speed){
    current = (current + 1) % totalFrames;
    previousTime = currentTime;
  }
  display.drawBitmap(x, y, frameArray[current], 32, 32, SSD1306_WHITE);
}

int currentRun = 0;
unsigned long previousRunTime = 0;

void drawRun(const unsigned char** frameArray, int speed){
  unsigned long currentRunTime = millis();
  if (currentRunTime - previousRunTime >= speed){
    currentRun = (currentRun + 1) % 6;
    previousRunTime = currentRunTime;
  }
  display.drawBitmap(0, 16, frameArray[currentRun], 128, 32, SSD1306_WHITE);
}
