        int cellY = 7 + (r * 16);

        if (tttBoard[r][c] == 1){
          display.setCursor(cellX, cellY);
          display.print("X");
        }
        else if (tttBoard[r][c] == 2){
          display.setCursor(cellX, cellY);
          display.print("O");
        }

        if (cursorX == c && cursorY == r) {
          display.drawRect(cellX - 4, cellY - 2, 13, 11, SSD1306_WHITE);
        }
      }
    }
    display.setCursor(40, 56);
    display.print("B3: Forfeit");
    display.display();
    return;
  }

  //animation & static moods
  if (currentState == WALK_TOWARDS && !joystickMoving && !actionActive){
    const unsigned char* moodSprite;

    if (currentTemp < 10.0){
      moodSprite = petCold;
      display.setCursor(68, 36);
      display.print("COLD! ");
    }
    else if (currentTemp > 30.0){
      moodSprite = petHot;
      display.setCursor(68, 36);
      display.print("HOT! ");
    }
    else if (pet.happiness < 25) moodSprite = petSad;
    else if (pet.hunger < 25) moodSprite = petHungry;
    else if (pet.energy < 25) moodSprite = petTired;
    else if (pet.hunger > 60 && pet.happiness > 60 && pet.energy > 60) moodSprite = petHappy;
    else moodSprite = petNeutral;

    display.drawBitmap(68, 2, moodSprite, 32, 32, SSD1306_WHITE);
  }else{
    switch(currentState){
      case WALK_RIGHT:   
        drawAnimation(walkRight, 2, animInterval, 68, 2);
        break;
      case WALK_LEFT:
        drawAnimation(walkLeft, 2, animInterval, 68, 2);
        break;
      case WALK_AWAY:
        drawAnimation(walkAway, 2, animInterval, 68, 2);
        break;
      case HULA_HOOPING:
        drawAnimation(hulahoop, 2, animInterval, 68, 2);
        break;
      case JUMP_ROPING:
        drawAnimation(jumprope, 2, animInterval, 68, 2);
        break;
      case LIFTING:
        drawAnimation(dumbbell, 3, animInterval, 68, 2);
        break;
      case EATING:
        drawAnimation(eat, 3, animInterval, 68, 2);
        break;
      case RUNNING:
        drawRun(run, animInterval);
        break;
      case WALK_TOWARDS: 
        if (actionActive) drawAnimation(walkTowards, 2, 600, 68, 2);
        else drawAnimation(walkTowards, 2, animInterval, 68, 2);
        break;
      default:
        display.drawBitmap(68, 2, petNeutral, 32, 32, SSD1306_WHITE);
        break;
    }
  }

  //stats
  display.setCursor(0, 2); 
  display.print("F:"); 

  display.setCursor(0, 24);
  display.print("P:"); 

  display.setCursor(0, 34);
  display.print("S:"); 

  display.setCursor(0, 44);
  display.print("E:"); 

  //buttons
  display.setCursor(16, 24);
  display.print("HUN");
  drawBar(42, 24, pet.hunger);

  display.setCursor(16, 34);
  display.print("HAP");
  drawBar(42, 34, pet.happiness);

  display.setCursor(16, 44);
  display.print("ENG");
  drawBar(42, 44, pet.energy);

  display.display();
}

void drawBar(int x, int y, int value){
  int barWidth = 80;
  int barHeight = 6;
  int fillWidth = map(value, 0, 100, 0, barWidth);

  display.drawRect(x, y, barWidth, barHeight, SSD1306_WHITE);       
  display.fillRect(x, y, fillWidth, barHeight, SSD1306_WHITE);      
}

//------------LOOP------------
void loop(){
  xValue = analogRead(X_PIN) - xCenter;
  yValue = analogRead(Y_PIN) - yCenter;

  if (abs(xValue) > deadzone || abs(yValue) > deadzone){
    joystickMoving = true;
  }else{
    joystickMoving = false;
  }

  if (millis() - lastTempRequest >= tempInterval){
    sensors.requestTemperatures();
    currentTemp = sensors.getTempCByIndex(0);
    lastTempRequest = millis();
  }

  checkButtons();
  updatePet();
  handleScreenLogic();

  if (joystickMoving && !tttPlaying){
    lastInteractionTime = millis();

    if (abs(xValue) > abs(yValue)){
      if (xValue > 0) changeState(WALK_RIGHT);
      else changeState(WALK_LEFT);
    }else{
      if (yValue > 0) changeState(WALK_AWAY);
      else changeState(WALK_TOWARDS);
    }

    if (!itemSpawned && (millis() - lastSpawnCheck >= spawnRollInterval)){
      lastSpawnCheck = millis();
      if (random(0, 100) < 5){
        itemSpawned = true;
        spawnedItemType = random(0, 2);
        tone(BUZZER_PIN, 1500, 80); 
      }
    }
  }else{
    if (currentScreen == SCREEN_MAIN && !actionActive){
      changeState(WALK_TOWARDS); 
    }
  }

  render();
  delay(30);
}
