  display.display();
  delay(1000);

  //joystick
  xCenter = analogRead(X_PIN);
  yCenter = analogRead(Y_PIN);

  pet.hunger = 80;
  pet.happiness = 80;
  pet.energy = 80;
  pet.age = 0;

  display.clearDisplay();
