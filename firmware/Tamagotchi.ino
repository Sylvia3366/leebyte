  if (tttPlaying) {
    //gridddd
    display.drawFastVLine(51, 4, 46, SSD1306_WHITE);
    display.drawFastVLine(76, 4, 46, SSD1306_WHITE);
    display.drawFastHLine(28, 18, 72, SSD1306_WHITE);
    display.drawFastHLine(28, 34, 72, SSD1306_WHITE);

    for (int r = 0; r < 3; r++) {
      for (int c = 0; c < 3; c++) {
